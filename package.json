{
  "name": "openclaw-company-secretary",
  "version": "2.0.0",
  "description": "AI-powered Company Secretary assistant for board meeting management, minute generation, resolution tracking, and video reporting",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "company-secretary": "./cli/secretary-cli.sh",
    "board-secretary": "./cli/secretary-cli.sh"
  },
  "files": [
    "dist/",
    "src/",
    "cli/",
    "scripts/",
    "docs/",
    "remotion.config.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "QUICKSTART.md",
    "clawhub.yaml"
  ],
  "scripts": {
    "dev": "remotion studio",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "render": "remotion render Main out/video.mp4",
    "secretary": "./cli/secretary-cli.sh",
    "dashboard": "./cli/secretary-cli.sh dashboard",
    "test": "node -r ts-node/register src/__tests__/index.test.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "chmod +x cli/secretary-cli.sh 2>/dev/null || true"
  },
  "keywords": [
    "company-secretary",
    "board-meeting",
    "meeting-minutes",
    "corporate-governance",
    "resolution-tracking",
    "action-items",
    "compliance",
    "board-management",
    "ai-assistant",
    "openclaw",
    "meeting-management",
    "video-reporting"
  ],
  "author": "justin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhenRobotics/openclaw-company-secretary.git"
  },
  "bugs": {
    "url": "https://github.com/ZhenRobotics/openclaw-company-secretary/issues"
  },
  "homepage": "https://github.com/ZhenRobotics/openclaw-company-secretary#readme",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.431"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.431",
    "@types/node": "^22.19.13",
    "@types/react": "^19.0.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
