# OpenClaw Video Generator - Multi-Provider Configuration
# 复制此文件为 .env 并填入你的 API 密钥

# ========================================
# Provider Priority Configuration
# ========================================
# 自动降级顺序（从左到右尝试）
# 国内建议: aliyun,tencent,azure,openai
# 海外建议: openai,azure,aliyun,tencent
TTS_PROVIDERS="aliyun,tencent,azure,openai"
ASR_PROVIDERS="aliyun,tencent,azure,openai"

# ========================================
# OpenAI Configuration
# ========================================
OPENAI_API_KEY="sk-proj-..."
OPENAI_API_BASE="https://api.openai.com/v1"

# TTS Voices: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE="nova"
OPENAI_TTS_MODEL="tts-1"

# ASR Model
OPENAI_ASR_MODEL="whisper-1"

# ========================================
# Azure Configuration
# ========================================
AZURE_SPEECH_KEY="your-azure-speech-key"
AZURE_SPEECH_REGION="eastasia"  # 或 chinaeast2（中国区）

# TTS Voice (中文神经语音)
# 女声: zh-CN-XiaoxiaoNeural, zh-CN-XiaoyiNeural, zh-CN-XiaohanNeural
# 男声: zh-CN-YunxiNeural, zh-CN-YunyangNeural, zh-CN-YunjianNeural
AZURE_TTS_VOICE="zh-CN-XiaoxiaoNeural"
AZURE_TTS_STYLE="general"  # 可选: cheerful, sad, angry, fearful, etc.

# ========================================
# 阿里云 Configuration
# ========================================
ALIYUN_ACCESS_KEY_ID="LTAI..."
ALIYUN_ACCESS_KEY_SECRET="your-secret"
ALIYUN_APP_KEY="your-app-key"  # TTS AppKey

# TTS Voice
# 女声: Aibao, Xiaoyun, Zhiqi, Aixia, Aitong
# 男声: Qingfeng, Zhiyuan, Laotie
ALIYUN_TTS_VOICE="Aibao"
ALIYUN_TTS_FORMAT="mp3"
ALIYUN_TTS_SAMPLE_RATE="16000"

# ASR Model
ALIYUN_ASR_MODEL="sambert-zhilingchuan-v1"

# ========================================
# 腾讯云 Configuration
# ========================================
TENCENT_SECRET_ID="AKI..."
TENCENT_SECRET_KEY="your-secret-key"
TENCENT_APP_ID="your-app-id"

# TTS Voice
# 智能女声: 101001(智瑜-情感女声), 101002(智聆-通用女声)
# 智能男声: 101003(智美-客服女声), 101004(智云-通用男声)
TENCENT_TTS_VOICE="101001"
TENCENT_TTS_SPEED="0"  # -2 到 2
TENCENT_TTS_VOLUME="0"  # -10 到 10

# ASR Engine
TENCENT_ASR_ENGINE="16k_zh"
